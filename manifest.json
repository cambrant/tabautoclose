{
  "author": "cambrant",
  "homepage_url": "https://github.com/cambrant/autoclosetabs",
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_area": "navbar"
  },
  "description": "Automatically close tabs matching certain regular expressions.",
  "icons": {
    "256": "icon.png"
  },
  "manifest_version": 2,
  "name": "Tab AutoClose",
  "permissions": [
    "contextualIdentities",
    "cookies",
    "bookmarks",
    "tabs",
    "storage"
  ],
  "options_ui": {
    "page": "options.html"
  },
  "incognito": "not_allowed",
  "version": "0.1"
}
